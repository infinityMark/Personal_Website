---
import Layout from '../layouts/Layout.astro';
import PhotoCard from '../components/PhotoCard.astro';
import Lightbox from '../components/Lightbox.astro';
import photos from '../data/photos.json';
import '../styles/global.css';
---

<Layout>
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16 md:pt-32 md:pb-24">
    <h1 class="section-title fade-up">
      Photography
    </h1>
    <p class="mt-3 text-charcoal/60 max-w-lg leading-relaxed fade-up">
      Light, shadow, and the moments in between. Photography is how I slow down and see the world more carefully.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-24 md:pb-32">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {photos.map((photo, i) => (
        <PhotoCard
          filename={photo.filename}
          title={photo.title}
          alt={photo.alt}
          index={i}
        />
      ))}
    </div>
  </section>

  <Lightbox />
</Layout>
