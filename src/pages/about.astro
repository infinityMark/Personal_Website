---
import Layout from '../layouts/Layout.astro';
import SkillBadge from '../components/SkillBadge.astro';
import '../styles/global.css';

const languages = [
  'TypeScript', 'JavaScript', 'Python', 'Go', 'Rust',
  'HTML & CSS', 'SQL', 'Bash',
];

const tools = [
  'React', 'Next.js', 'Astro', 'Node.js',
  'FastAPI', 'Docker', 'Git', 'PostgreSQL',
  'AWS', 'Tailwind CSS', 'Figma',
];
---

<Layout>
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16 md:pt-32 md:pb-24">
    <h1 class="section-title fade-up">About Me</h1>
  </section>

  <!-- Intro -->
  <section class="max-w-3xl mx-auto px-6 pb-16 fade-up">
    <p class="text-lg text-charcoal/80 leading-relaxed">
      I'm a software engineer who believes good code is clear, deliberate, and kind to the people who read it.
      I work across the stack — from database schemas to shipping interfaces — and I care about the craft at every layer.
    </p>
    <p class="mt-4 text-lg text-charcoal/80 leading-relaxed">
      Outside of engineering, I'm drawn to photography. It's a different kind of problem-solving:
      one about light, composition, and patience. I find that the two disciplines — building systems and
      capturing images — complement each other surprisingly well.
    </p>
  </section>

  <!-- Skills -->
  <section class="max-w-3xl mx-auto px-6 pb-12 fade-up">
    <h2 class="font-display text-xl text-charcoal mb-4">Languages</h2>
    <div class="flex flex-wrap gap-2">
      {languages.map((lang) => <SkillBadge label={lang} />)}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-12 fade-up">
    <h2 class="font-display text-xl text-charcoal mb-4">Tools & Frameworks</h2>
    <div class="flex flex-wrap gap-2">
      {tools.map((tool) => <SkillBadge label={tool} />)}
    </div>
  </section>

  <!-- Contact -->
  <section class="max-w-3xl mx-auto px-6 pb-24 md:pb-32 fade-up">
    <h2 class="font-display text-xl text-charcoal mb-3">Get in touch</h2>
    <p class="text-charcoal/60">
      Open to interesting conversations — reach me at
      <a href="mailto:mark@example.com" class="text-accent hover:text-accent/70 transition-colors ml-1">
        mark@example.com
      </a>
    </p>
  </section>
</Layout>
